# Telegram AI Agent Config

# Telegram Bot Token (Get this from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram User ID (The bot will only accept commands from this ID for security)
AUTHORIZED_USER_ID=your_telegram_user_id_here

# Gemini API Key (Primary LLM for drafts and summaries)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Optional fallback if Gemini quota is exceeded)
OPENAI_API_KEY=your_openai_api_key_here

# Email Server Credentials (IMAP/SMTP)
EMAIL_USERNAME=your_email@example.com
EMAIL_PASSWORD=your_app_specific_password_here

# IMAP/SMTP server settings (e.g., for Gmail)
EMAIL_IMAP_SERVER=imap.gmail.com
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=465
