# Telegram AI Agent Config

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram User ID — only this ID can send commands to the bot
# Get yours from @userinfobot on Telegram
AUTHORIZED_USER_ID=your_telegram_user_id_here

# ── AI Providers ──────────────────────────────────────────────────────────────
# Gemini (Primary — REQUIRED)
GEMINI_API_KEY=your_gemini_api_key_here

# Claude by Anthropic (Fallback #1 — optional)
CLAUDE_API_KEY=your_claude_api_key_here

# OpenAI (Fallback #2 — optional)
OPENAI_API_KEY=your_openai_api_key_here

# Fallback order: Gemini 2.5 Flash → Gemini 2.0 Flash → Gemini Lite →
#                 Claude 3 Haiku → OpenAI GPT-4o-mini

# ── Email Server Credentials ─────────────────────────────────────────────────
EMAIL_USERNAME=your_email@example.com
EMAIL_PASSWORD=your_app_specific_password_here

# IMAP / SMTP settings (Gmail defaults shown)
EMAIL_IMAP_SERVER=imap.gmail.com
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=465

# ── Auto-Polling ──────────────────────────────────────────────────────────────
# How often (in minutes) the bot checks for new emails when /watch is active
POLL_INTERVAL_MINUTES=5
