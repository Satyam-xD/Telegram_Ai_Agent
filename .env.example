# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
AUTHORIZED_USER_ID=your_telegram_user_id_here   # get from @userinfobot

# ── AI Providers ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here          # required (primary AI)
CLAUDE_API_KEY=your_claude_api_key_here          # optional (fallback #1)
OPENAI_API_KEY=your_openai_api_key_here          # optional (fallback #2)

# ── Email Credentials ───────────────────────────────────────────────────────────────
EMAIL_USERNAME=your@gmail.com
EMAIL_PASSWORD=your_app_specific_password_here   # Gmail: use App Password

# ── Resend (add this on Render to fix SMTP port blocking) ──────────────────────────
# Sign up free at https://resend.com (3,000 emails/month free)
# If set, Resend is used instead of SMTP for all outgoing mail.
RESEND_API_KEY=

# ── Email Server (Gmail defaults) ─────────────────────────────────────────────
EMAIL_IMAP_SERVER=imap.gmail.com
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=465

# ── Monitoring ────────────────────────────────────────────────────────────────
POLL_INTERVAL_MINUTES=5

# ── Render / Webhook (production only) ───────────────────────────────────────
# Leave WEBHOOK_URL blank for local polling mode.
# On Render: set WEBHOOK_URL=https://<your-service-name>.onrender.com
# Render injects PORT automatically — do not set it manually.
WEBHOOK_URL=
